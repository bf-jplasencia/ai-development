# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Poetry ────────────────────────────────────────────────────────────────────
# Uncomment the next line if you do NOT want to commit the lock file.
# poetry.lock

# ── Distribution / packaging ──────────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg
MANIFEST

# ── Testing & coverage ────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# ── Type checkers ─────────────────────────────────────────────────────────────
.mypy_cache/
.dmypy.json
.pyright/

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
*.env
!.env.example

# ── IDEs & editors ────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS artifacts ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Docker ────────────────────────────────────────────────────────────────────
# (docker-compose.override.yml is intentionally ignored to avoid leaking
#  local overrides with secrets)
docker-compose.override.yml

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/
